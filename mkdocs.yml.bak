site_name: Homelab
site_url: https://192.168.1.3
theme:
  features:
    - navigation.footer
  name: material
  font:
    text: Merriweather Sans
    code: Red Hat Mono
  icon:
    logo: fontawesome/solid/o
  palette:
    - scheme: slate
      toggle:
        icon: material/weather-sunny
        name: Dark mode
      primary: green
      accent: deep purple
    - scheme: default
      toggle:
        icon: material/weather-night
        name: Light mode
      primary: blue
      accent: deep orange
markdown_extensions:
  - tables
  - attr_list
  - admonition
  - pymdownx.details
  - pymdownx.inlinehilite
  - pymdownx.snippets
  - pymdownx.tabbed:
      alternate_style: true
  - pymdownx.highlight:
      anchor_linenums: true
      line_spans: __span
      pygments_lang_class: true
  - pymdownx.emoji:
      emoji_index: !!python/name:material.extensions.emoji.twemoji
      emoji_generator: !!python/name:material.extensions.emoji.to_svg
  - pymdownx.superfences:
      custom_fences:
        - name: mermaid
          class: mermaid
          format: !!python/name:pymdownx.superfences.fence_code_format
nav:
  - Welcome: index.md
  - Host: host.md
  - Hosts: hosts.md
  - Scan Results: scan_results.md
  - Disk Space: disk_space.md
  - System Info: system_info.md
  - Services: services.md
  - User Audit: user_audit.md
  - Ping Report: ping_report.md
  - Concerts: concerts.md
  - Homelab: homelab.md
  - MediaStack Applications: mdeiastack_apps.md
  - Apps to Investigate: apps_to_investigate.md
  - Code Examples: code-examples.md
  - Git Commands: git.commands.md
  - Git Info: git_nfo.md
  - Network Devices: network_devices.md
  - Network Diagram: network_diagram.md
  - Todo: todo.md
copyright: Copyright &copy; 2025 C. O'Shaughnessy as inspired by James Willett
